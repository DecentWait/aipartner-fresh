{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AIPartner",
  "version": "1.0.0",
  "identifier": "com.aipartner.fresh",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm.cmd --prefix frontend run dev -- --configLoader runner",
    "beforeBuildCommand": "npm.cmd --prefix frontend run build"
  },
  "app": {
    "windows": [
      {
        "title": "AIPartner",
        "width": 1440,
        "height": 900,
        "minWidth": 1080,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
